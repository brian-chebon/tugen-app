rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Public Content (read-only for all) ───
    match /categories/{doc} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    match /phrases/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /decks/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /vocabCards/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /stories/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /storySegments/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ─── User Data (private to each user) ───
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /progress/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /quizResults/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /stats/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /achievements/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /bookmarks/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Leaderboard (read by all authenticated, write own entry) ───
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
